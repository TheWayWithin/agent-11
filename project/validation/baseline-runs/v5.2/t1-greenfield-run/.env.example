# Tinylink environment configuration
# Copy this file to `.env` and fill in real values for local dev.

# Environment: `development` or `production`.
# In `production`, session cookies are marked `secure` (HTTPS-only).
NODE_ENV=development

# Port Express listens on. Railway injects PORT in production.
PORT=3000

# Cookie signing secret. MUST be a long random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# (>= 32 random bytes recommended).
SESSION_SECRET=dev-only-not-secret-change-me-in-prod-please-1234567890

# Path to the main SQLite database file.
# Local dev default: ./data/tinylink.db
# Production (Railway with persistent volume): /data/tinylink.db
DB_PATH=./data/tinylink.db

# Path to the session store SQLite file (kept separate from main DB
# for operational simplicity — wipe sessions without touching user data).
# Local dev default: ./data/sessions.db
# Production: /data/sessions.db
SESSION_DB_PATH=./data/sessions.db

# Public base URL — used to build the shareable short URL displayed
# back to users (e.g. {BASE_URL}/x4Ka9).
# Local dev default: http://localhost:3000
# Production: e.g. https://tinylink.app
BASE_URL=http://localhost:3000
