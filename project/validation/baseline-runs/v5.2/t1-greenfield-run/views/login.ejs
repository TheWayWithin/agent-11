<%- include('partials/header', { title: title }) %>

<section class="card">
  <h1>Sign in</h1>

  <% if (error) { %>
    <p class="error" role="alert"><%= error %></p>
  <% } %>

  <form method="post" action="/login" class="stack" autocomplete="off" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

    <label>
      <span>Email</span>
      <input
        type="email"
        name="email"
        value="<%= email %>"
        required
        autocomplete="email"
        autofocus
      />
    </label>

    <label>
      <span>Password</span>
      <input
        type="password"
        name="password"
        required
        autocomplete="current-password"
      />
    </label>

    <button type="submit" class="primary">Sign in</button>
  </form>

  <p class="muted">
    No account yet? <a href="/signup">Create one</a>.
  </p>
</section>

<%- include('partials/footer') %>
